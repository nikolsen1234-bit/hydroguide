{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "src/index.css",
    "scripts/**/*.mjs",
    "../backend/_middleware.js",
    "../backend/api/**/*.js",
    "../backend/admin/**/*.js",
    "../backend/workers/**/*.js",
    "../backend/workers/**/*.ts",
    "../backend/api/**/*.test.mjs",
    "../backend/cloudflare/**/*.test.mjs"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "../backend/api/**/*.js",
    "../backend/admin/**/*.js",
    "../backend/workers/**/*.{js,ts}",
    "scripts/**/*.mjs"
  ],
  "ignoreExportsUsedInFile": true,
  "ignoreDependencies": ["wrangler"],
  "wrangler": {
    "config": [
      "../backend/cloudflare/api.wrangler.jsonc",
      "../backend/cloudflare/report.wrangler.jsonc",
      "../backend/cloudflare/ai.wrangler.jsonc",
      "../backend/cloudflare/admin.wrangler.jsonc"
    ]
  },
  "rules": {
    "duplicates": "off"
  }
}
