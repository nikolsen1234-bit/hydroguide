#!/bin/sh
# Pre-commit hook for HydroGuide.
#
# Two tiers of checks:
#
# 1) TRACKED (in backend/scripts/) — every clone has these. They MUST pass.
#    If node is missing, the commit is blocked: install Node 22 LTS.
#
# 2) PRIVATE (in private/scripts/) — git-crypt encrypted; only present after
#    `git-crypt unlock`. Runs if available; missing scripts skip silently.
#    Tier 1 + CI on PR catch what Tier 2 would catch for fresh clones.

set -e

find_node () {
  if command -v node >/dev/null 2>&1; then
    command -v node
    return 0
  fi
  for candidate in \
    "/c/Program Files/nodejs/node.exe" \
    "/c/Program Files (x86)/nodejs/node.exe"
  do
    if [ -x "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

NODE_BIN="$(find_node || true)"
if [ -z "$NODE_BIN" ]; then
  echo "pre-commit blocked: 'node' is not on PATH."
  echo "  Install Node.js 22 LTS to enable the required checks."
  exit 1
fi

# --- Tier 1: tracked checks (must pass) ---

run_tracked () {
  script="$1"
  shift
  if [ ! -f "$script" ]; then
    echo "pre-commit blocked: required check missing: $script"
    echo "  This script is tracked in the repo. If you do not have it, your clone is corrupt."
    echo "  Run: git checkout -- $script"
    exit 1
  fi
  "$NODE_BIN" "$script" "$@" || exit 1
}

run_tracked backend/scripts/check-no-console.mjs --staged
run_tracked backend/scripts/check-hardcoded-ids.mjs --staged
run_tracked backend/scripts/check-postmessage.mjs --staged
run_tracked backend/scripts/check-worker-hygiene.mjs --staged
run_tracked backend/scripts/check-trace-id.mjs --staged

# --- Tier 2: private checks (skip if missing) ---

run_private () {
  script="$1"
  shift
  if [ -f "$script" ]; then
    "$NODE_BIN" "$script" "$@" || exit 1
  fi
}

run_private private/scripts/check-secrets.mjs --staged
run_private private/scripts/check-doc-style.mjs --staged
run_private private/scripts/check-agent-guardrails.mjs --local
run_private private/scripts/check-tracking.mjs --staged
