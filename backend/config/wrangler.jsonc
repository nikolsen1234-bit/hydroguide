{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "hydroguide-w-r2",
  // account_id: set via CLOUDFLARE_ACCOUNT_ID env var or wrangler login
  "main": "../services/ai/index.ts",
  "compatibility_date": "2026-03-29",
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false
    }
  },
  "dev": {
    "ip": "127.0.0.1",
    "port": 8788
  },
  "ai": {
    "binding": "AI",
    "remote": true
  },
  "kv_namespaces": [
    {
      "binding": "PROMPT_KV",
      "id": "REPLACE_WITH_KV_NAMESPACE_ID",
      "remote": true
    }
  ],
  "secrets_store_secrets": [
    {
      "binding": "WORKER_API_KEY",
      "store_id": "REPLACE_WITH_SECRETS_STORE_ID",
      "secret_name": "WORKER_API_KEY"
    },
    {
      "binding": "AI_GATEWAY_AUTH_TOKEN",
      "store_id": "REPLACE_WITH_SECRETS_STORE_ID",
      "secret_name": "AI_GATEWAY_AUTH_TOKEN"
    },
    {
      "binding": "AI_SEARCH_API_TOKEN",
      "store_id": "REPLACE_WITH_SECRETS_STORE_ID",
      "secret_name": "AI_SEARCH_API_TOKEN"
    },
    {
      "binding": "AI_EXPORT_PASSWORD_HASH",
      "store_id": "REPLACE_WITH_SECRETS_STORE_ID",
      "secret_name": "AI_EXPORT_PASSWORD_HASH"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2_BUCKET",
      "bucket_name": "hydroguide-r2"
    }
  ],
  "vars": {
    "OPENAI_MODEL_PRIMARY": "gpt-5.1",
    "OPENAI_MODEL_FALLBACK": "gpt-5.4-mini",
    "ALLOWED_ORIGINS": "https://hydroguide.no,https://www.hydroguide.no,http://127.0.0.1:5173,http://localhost:5173",
    "RETRIEVAL_BACKEND": "auto",
    "AI_SEARCH_ACCOUNT_ID": "REPLACE_WITH_ACCOUNT_ID",
    "AI_SEARCH_INSTANCE": "ai-search",
    "AI_SEARCH_MAX_RESULTS": "10",
    "AI_SEARCH_MATCH_THRESHOLD": "0.35",
    "AI_SEARCH_ENABLE_RERANKING": "true",
    "AI_SEARCH_ENABLE_QUERY_REWRITE": "false",
    "AI_GATEWAY_ENABLED": "true",
    "AI_GATEWAY_ACCOUNT_ID": "REPLACE_WITH_ACCOUNT_ID",
    "AI_GATEWAY_ID": "hydroguide-ai-gateway",
    "AI_GATEWAY_CACHE_TTL": "3600",
    "AI_GATEWAY_REQUEST_TIMEOUT_MS": "8000",
    "AI_GATEWAY_MAX_ATTEMPTS": "3",
    "AI_GATEWAY_RETRY_DELAY_MS": "500",
    "AI_GATEWAY_RETRY_BACKOFF": "exponential",
    "NARRATIVE_MODE": "supplement",
    "NARRATIVE_MAX_WORDS": "250",
    "NARRATIVE_MAX_SENTENCES": "10",
    "RETRIEVAL_STRATEGY": "auto",
    "SELF_FEEDBACK_ENABLED": "false",
    "SELF_FEEDBACK_MODEL": "gpt-5.4-mini",
    "SELF_FEEDBACK_REGENERATE": "false",
    "USER_FEEDBACK_ENABLED": "false",
    "VECTORIZE_ENABLED": "false",
    "VECTORIZE_EMBEDDING_MODEL": "@cf/baai/bge-m3"
  }
}
