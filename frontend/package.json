{
  "name": "energi-konfig",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/update-build-info.mjs",
    "prepare": "cd .. && git config core.hooksPath .githooks",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:test": "npm run build && node scripts/copy-build-info-to-dist.mjs && node scripts/copy-build-to-test.mjs",
    "preview": "vite preview",
    "api:keys": "node scripts/manage-api-keys.mjs",
    "check:excel": "node scripts/check-excel-reference.mjs",
    "check:knip": "npx --yes knip"
  },
  "dependencies": {
    "@fontsource-variable/manrope": "^5.2.8",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "8.0.2",
    "wrangler": "^4.78.0"
  }
}
