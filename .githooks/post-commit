#!/bin/sh
# Post-commit hook for HydroGuide.
#
# Records the commit in the per-machine agent-sync log IF the private toolkit
# is present (git-crypt unlocked). Fresh clones without the key skip silently.

if command -v node >/dev/null 2>&1 && [ -f private/scripts/record-commit.mjs ]; then
  node private/scripts/record-commit.mjs
fi
